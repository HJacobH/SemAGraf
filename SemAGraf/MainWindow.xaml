<Window x:Class="SemAGraf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dopravní Síť - Simulátor" Height="724" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
            <StackPanel>

                <GroupBox Header="1. Soubor a načtení" Padding="5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Načíst JSON" Click="BtnLoad_Click" Grid.Column="0" Margin="0,0,2,0" Height="25"/>
                        <Button Content="Uložit JSON" Click="BtnSave_Click" Grid.Column="1" Margin="2,0,0,0" Height="25"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="2. Správa obcí (Uzlů)" Padding="5" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNodeId" Grid.Column="0" Margin="0,0,5,0" ToolTip="Název obce (ID)"/>
                            <TextBox x:Name="TxtNodeX" Grid.Column="1" Margin="0,0,5,0" ToolTip="Souřadnice X"/>
                            <TextBox x:Name="TxtNodeY" Grid.Column="2" ToolTip="Souřadnice Y"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Vyhledat uzel" Click="BtnSearchNode_Click" Grid.Column="0" Margin="0,0,2,0"/>
                            <Button Content="Přidat uzel" Click="BtnAddNode_Click" Grid.Column="1" Margin="2,0,0,0" Background="#e6ffe6"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="3. Správa komunikací" Padding="5" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CbFrom" Grid.Column="0" Margin="0,0,2,0" DisplayMemberPath="Id" ToolTip="Z (Uzel A)"/>
                            <ComboBox x:Name="CbTo" Grid.Column="1" Margin="2,0,0,0" DisplayMemberPath="Id" ToolTip="Do (Uzel B)"/>
                        </Grid>

                        <TextBox x:Name="TxtNewEdgeWeight" Margin="0,0,0,5" Width="100" HorizontalAlignment="Left" ToolTip="Čas (minuty)" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Přidat cestu" Click="BtnAddEdge_Click" Grid.Column="0" Margin="0,0,2,0" Background="#e6ffe6"/>
                            <Button Content="Smazat cestu" Click="BtnDeleteEdge_Click" Grid.Column="1" Margin="2,0,0,0" Background="#ffe6e6"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="4. Dopravní omezení" Padding="5" Margin="0,0,0,10">
                    <StackPanel>
                        <Button Content="Označit vybraný úsek jako neprůjezdný" Click="BtnSetProblematic_Click" Margin="0,0,0,5" Background="Orange"/>
                        <Button Content="Zrušit všechny uzavírky" Click="BtnClearProblematic_Click" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="5. Vyhledávání tras" Padding="5">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtStart" Grid.Column="0" Margin="0,0,2,0" ToolTip="Startovní obec" />
                            <TextBox x:Name="TxtEnd" Grid.Column="1" Margin="2,0,0,0" ToolTip="Cílová obec" />
                        </Grid>

                        <Button Content="Najít nejkratší a alternativní trasy" Click="BtnCalculate_Click" Height="35" FontWeight="Bold" Background="#e6f2ff"/>

                        <TextBlock Text="Nalezené trasy:" Margin="0,10,0,5" FontWeight="Bold"/>

                        <ListBox x:Name="LbPaths" Height="150" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsVisible}" 
                              Content="{Binding Label}" 
                              Foreground="{Binding Color}"
                              FontWeight="Bold"
                              Click="PathVisibility_Changed" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border BorderBrush="Gray" BorderThickness="1" Grid.Row="0" Margin="0,0,0,10" Background="White">
                <Canvas x:Name="GraphCanvas" ClipToBounds="True" />
            </Border>

            <GroupBox Header="Vektor následníků (Tabulka 1)" Grid.Row="1" Margin="0,0,0,10">
                <DataGrid x:Name="DgSuccessors" AutoGenerateColumns="True" IsReadOnly="True" />
            </GroupBox>

            <TextBlock x:Name="TxtStatus" Grid.Row="2" Text="Aplikace připravena." FontWeight="Bold" Foreground="DarkSlateGray" />
        </Grid>
    </Grid>
</Window>
